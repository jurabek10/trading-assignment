# Copy to apps/server/.env and fill in your LS증권 Open API credentials.
# Issue them at https://openapi.ls-sec.co.kr (모의/실전 앱 등록).

# Set to 1 to use the live LS feed; leave unset/0 for the mock feed.
USE_LS=1

LS_APP_KEY=your-app-key
LS_APP_SECRET=your-app-secret

# Optional overrides (defaults shown):
# LS_REST_BASE=https://openapi.ls-sec.co.kr:8080
# LS_WS_BASE=wss://openapi.ls-sec.co.kr:9443/websocket

# Server
# PORT=8080
# ALLOWED_ORIGIN=*
